<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <title>Add Developer | Velocis</title>

    <link href="/developer.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body>

<!-- Sidebar -->
<div class="sidebar">
    <img src="/images/velocis-logo.png" alt="Velocis Logo" class="logo">

    <ul class="nav-links">
        <li><a th:href="@{/taskassignment/assignTask}"><i class="bi bi-plus-circle"></i> Create Task</a></li>
        <li class="active"><a th:href="@{/taskassignment/developer}"><i class="bi bi-person-plus"></i> Add Developer</a></li>
        <li><a th:href="@{/taskassignment/project}"><i class="bi bi-folder-plus"></i> Add Project</a></li>
        <li><a th:href="@{/taskassignment/assignedTask}"><i class="bi bi-list-task"></i> All Tasks</a></li>
		<li><a href="@{/taskassignment/myProfile}"><i class="bi bi-person-circle"></i> My Profile</a></li>
        <li><a href="#"><i class="bi bi-bar-chart"></i> Reports</a></li>
    </ul>

    <div class="footer">© 2025 Velocis Systems Pvt. Ltd.</div>
</div>

<!-- Main Content -->
<div class="main-content">

    <div class="developer-form">

        <!-- Success Message -->
        <div th:if="${message}" class="success-box" th:text="${message}"></div>

        <h1>Add Developer</h1>

        <form th:action="@{/taskassignment/saveDeveloper}" method="post" enctype="multipart/form-data">

            <div class="form-group">
                <label for="fullName">Developer Name *</label>
				<select class="filter-select" onclick="setEmail()">
							  <option value="">Select</option>
						      <option th:each="p : ${developers}" th:value="${p.id}" th:text="${p.userName}"></option>
				            </select>
            </div>

            <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" placeholder="Enter email" disabled="true" required />
            </div>

            <div class="form-group">
                <label for="role">Role *</label>
                <select id="role" name="role" required>
                    <option value="">-- Select Role --</option>
                    <option value="Backend Developer">Backend Developer</option>
                    <option value="Frontend Developer">Frontend Developer</option>
                    <option value="Full Stack Developer">Full Stack Developer</option>
                    <option value="Tester">Tester</option>
                </select>
            </div>

            <div class="form-group">
                <label for="experience">Experience (Years) *</label>
                <input type="number" id="experience" name="experience" min="0" placeholder="e.g. 3" required />
            </div>

            <div class="form-group">
                <label for="resumeFile">Upload Resume (PDF)</label>
                <input type="file" id="resumeFile" name="resumeFile" accept=".pdf" />
            </div>

            <button type="submit" class="btn-submit">Save Developer</button>

        </form>

    </div>
</div>
<script>
function setEmail() {
    const select = document.getElementById("developerSelect");
    const selectedOption = select.options[select.selectedIndex];

    const email = selectedOption.getAttribute("data-email");
    document.getElementById("email").value = email || "";
}
</script>
</body>
</html>
