server:
  port: 8082

spring:
  application:
    name: api-gateway

  cloud:
    gateway:
      routes:
        - id: assignmentoffice
          uri: lb://AssignmentOffice
          predicates:
            - Path=/taskRest/**
          filters:
            - RewritePath=/taskRest/(?<remaining>.*), /${remaining}

eureka:
  instance:
    prefer-ip-address: true

  client:
    fetch-registry: true
    register-with-eureka: true
    service-url:
      defaultZone: http://localhost:8761/eureka
