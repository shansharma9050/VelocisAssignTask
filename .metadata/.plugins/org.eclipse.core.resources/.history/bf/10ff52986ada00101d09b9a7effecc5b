public class TestMainClass {

	public static int getMissingNumber(int[] a, int num) {

		int sum = 0, fin = 0, ret = 0;
		sum = num * (num + 1) / 2;

		for (int arr : a) {
			fin += arr;
		}
		ret = sum - fin;
	
		return ret;
	}
	
	public static void main(String[] args) {
		
		int[] a = {1,3,5,4};
		int missingNumber = getMissingNumber(a, 5);
		
	}

}
