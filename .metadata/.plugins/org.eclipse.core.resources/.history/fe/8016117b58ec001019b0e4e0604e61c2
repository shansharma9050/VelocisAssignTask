/* ------------------------------
   GLOBAL PAGE STYLE (BACKGROUND IMAGE)
------------------------------ */
body {
    margin: 0;
    padding: 0;
    font-family: "Segoe UI", Arial, sans-serif;

    background-image: url("/images/Image1.png");
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;

    min-height: 100vh;
    position: relative;
}

/* Soft overlay for readability */
body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: rgba(255, 255, 255, 0.65);
    z-index: 0;
}

/* ------------------------------
   CENTER WRAPPER
------------------------------ */
.verification-wrapper {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 20px;

    position: relative;
    z-index: 1;
}

/* ------------------------------
   CARD CONTAINER
------------------------------ */
.verification-card {
    background: #ffffff;
    width: 420px;
    padding: 35px;
    border-radius: 14px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    text-align: center;
    animation: fadeIn 0.4s ease;
}

/* Fade Animation */
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ------------------------------
   LOGO
------------------------------ */
.logo-container {
    margin-bottom: 15px;
}

.logo {
    width: 130px;
}

/* ------------------------------
   HEADINGS
------------------------------ */
h2 {
    margin: 10px 0 5px;
    font-size: 22px;
    font-weight: 600;
    color: #2d3748;
}

.subtitle {
    color: #6c757d;
    margin-bottom: 25px;
}

/* ------------------------------
   FORM INPUTS
------------------------------ */
form label {
    display: block;
    text-align: left;
    margin: 12px 0 6px;
    font-size: 14px;
    font-weight: 500;
    color: #444;
}

form input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #cfd7e2;
    border-radius: 8px;
    margin-bottom: 10px;
    font-size: 15px;
    transition: 0.2s;
}

form input:focus {
    border-color: #3b82f6;
    outline: none;
    box-shadow: 0 0 3px rgba(59,130,246,0.4);
}

/* ------------------------------
   BUTTON STYLES
------------------------------ */
.btn-primary,
.btn-secondary {
    width: 100%;
    padding: 12px;
    border: none;
    font-size: 15px;
    border-radius: 8px;
    cursor: pointer;
    margin-top: 10px;
    transition: 0.2s;
    font-weight: 600;
}

/* Blue Button */
.btn-primary {
    background: #2563eb;
    color: white;
}

.btn-primary:hover {
    background: #1e4fcc;
}

/* Grey Button */
.btn-secondary {
    background: #e5e7eb;
    color: #374151;
}

.btn-secondary:hover {
    background: #d5d6db;
}

/* ------------------------------
   SUCCESS & ERROR MESSAGES
------------------------------ */
.message {
    margin-top: 12px;
    font-size: 14px;
    font-weight: 500;
}

.message.success {
    color: #059669;
}

.message.error {
    color: #dc2626;
}

/* ------------------------------
   NOTE BELOW FORM
------------------------------ */
.note {
    margin-top: 20px;
    font-size: 14px;
    color: #555;
}

/* === Loader Overlay === */
#loaderOverlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 10, 10, 0.6);
    display: none;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    z-index: 9999;
    color: white;
    font-family: "Poppins", sans-serif;
    text-align: center;
}

/* === Rotating Loader === */
.loader {
    border: 5px solid rgba(255, 255, 255, 0.3);
    border-top: 5px solid #00a8e8;
    border-radius: 50%;
    width: 60px;
    height: 60px;
    animation: spin 1s linear infinite;
    margin-left: auto;
    margin-right: auto;
    margin-top: 70px;
    margin-bottom: auto;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* ------------------------------
   MOBILE OPTIMIZATION
------------------------------ */
@media (max-width: 480px) {
    body::before {
        display: none;
    }

    .verification-card {
        width: 100%;
        padding: 25px;
    }
}
