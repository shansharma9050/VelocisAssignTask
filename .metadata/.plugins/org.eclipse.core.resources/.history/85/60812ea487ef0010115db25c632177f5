	 * .roles("ADMIN") .build();
	 * 
	 * UserDetails user=User.builder() .username("User")
	 * .password(passwordEncorder().encode("654321")) .roles("USER") .build();
	 * 
	 * 
	 * 
	 * return new InMemoryUserDetailsManager(admin,user); }
	 */

}
