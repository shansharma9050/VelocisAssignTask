/* ------------------------------
   GLOBAL PAGE STYLE (BACKGROUND IMAGE)
------------------------------ */
body {
    margin: 0;
    padding: 0;
    font-family: "Segoe UI", Arial, sans-serif;

    background-image: url("/images/Image1.png");
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    min-height: 100vh;

    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

/* Soft overlay for readability */
body::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.65);
    z-index: 0;
}

/* ------------------------------
   CENTER WRAPPER
------------------------------ */
.login-container {
    max-width: 420px;
    width: 100%;
    margin: 60px auto;
    background: #ffffff;
    padding: 35px;
    border-radius: 14px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    text-align: center;
    animation: fadeIn 0.4s ease;

    position: relative;
    z-index: 1;
}

/* Fade Animation */
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* ------------------------------
   LOGO
------------------------------ */
.logo-container {
    margin-bottom: 15px;
}

.logo {
    width: 130px;
}

/* ------------------------------
   HEADINGS
------------------------------ */
h2 {
    margin: 10px 0 25px;
    font-size: 22px;
    font-weight: 600;
    color: #2d3748;
}

/* ------------------------------
   MESSAGES
------------------------------ */
.success-message {
    color: #059669;
    font-size: 14px;
    margin-bottom: 10px;
}

.error-message {
    color: #dc2626;
    font-size: 14px;
    margin-bottom: 10px;
}

.info-message {
    color: #2563eb;
    font-size: 14px;
    margin-bottom: 10px;
}

/* ------------------------------
   FORM INPUTS
------------------------------ */
.form-group {
    text-align: left;
    margin-bottom: 15px;
}

.form-group label {
    display: block;
    margin-bottom: 6px;
    font-size: 14px;
    font-weight: 500;
    color: #444;
}

.form-group input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #cfd7e2;
    border-radius: 8px;
    font-size: 15px;
    transition: 0.2s;
}

.form-group input:focus {
    border-color: #3b82f6;
    outline: none;
    box-shadow: 0 0 3px rgba(59,130,246,0.4);
}

/* ------------------------------
   BUTTONS
------------------------------ */
.btn-login {
    width: 100%;
    padding: 12px;
    border: none;
    background: #2563eb;
    color: white;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    cursor: pointer;
    transition: 0.2s;
    margin-top: 10px;
}

.btn-login:hover {
    background: #1e4fcc;
}

/* ------------------------------
   FOOTER LINK
------------------------------ */
.form-footer {
    margin-top: 20px;
    font-size: 14px;
}

.form-footer a {
    color: #2563eb;
    text-decoration: none;
}

.form-footer a:hover {
    text-decoration: underline;
}

/* ------------------------------
   SOCIAL LOGIN BUTTONS
------------------------------ */
.social-login {
    list-style: none;
    padding: 0;
    margin-top: 20px;
}

.social-login li {
    margin-bottom: 12px;
}

.social-btn {
    width: 100%;
    padding: 10px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border: 1px solid #cfd7e2;
    border-radius: 8px;
    background: #f5f5f5;
    cursor: pointer;
    font-weight: 500;
    transition: 0.2s;
}

.social-btn img {
    width: 20px;
    height: 20px;
}

.social-btn:hover {
    background: #e5e7eb;
}

/* ------------------------------
   MOBILE OPTIMIZATION
------------------------------ */
@media (max-width: 480px) {
    body::before {
        display: none; /* better performance on small devices */
    }

    .login-container {
        margin: 20px;
        padding: 25px;
    }
}
